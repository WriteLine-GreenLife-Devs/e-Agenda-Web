@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Contato";
}

@model ExcluirContatoViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <input asp-for="Id" type="hidden">

    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Deseja realmente excluir este contato?
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-4 fw-semibold text-uppercase small" style="color: #fff4e8;">ID</dt>
        <dd class="col-sm-8 text-break">@Model.Id</dd>

        <dt class="col-sm-4 fw-semibold text-uppercase small" style="color: #fff4e8;">Nome</dt>
        <dd class="col-sm-8">@Model.Nome</dd>

        <dt class="col-sm-4 fw-semibold text-uppercase small" style="color: #fff4e8;">Telefone</dt>
        <dd class="col-sm-8">@Model.Telefone</dd>

        <dt class="col-sm-4 fw-semibold text-uppercase small" style="color: #fff4e8;">Email</dt>
        <dd class="col-sm-8">@Model.Email</dd>

        @if (!string.IsNullOrEmpty(Model.Cargo))
        {
            <dt class="col-sm-4 fw-semibold text-uppercase small" style="color: #fff4e8;">Cargo</dt>
            <dd class="col-sm-8">@Model.Cargo</dd>
        }

        @if (!string.IsNullOrEmpty(Model.Empresa))
        {
            <dt class="col-sm-4 fw-semibold text-uppercase small" style="color: #fff4e8;">Empresa</dt>
            <dd class="col-sm-8">@Model.Empresa</dd>
        }
    </dl>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>
