@using eAgendaWeb.Modulos.ModuloTarefas.Apresentacao
@using eAgendaWeb.Modulos.ModuloTarefas.Dominio

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Editar Tarefa";
}

@model EditarTarefaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width:620px;" asp-action="Editar"
      method="post">

    <input asp-for="Id" type="hidden" id="TarefaId" />

    <div class="mb-3">
        <label asp-for="Titulo" class="form-label fw-semibold text-primary text-uppercase small">
            Título
        </label>
        <input asp-for="Titulo" class="form-control" />
        <span asp-validation-for="Titulo" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Prioridade" class="form-label fw-semibold text-primary text-uppercase small">
            Prioridade
        </label>
        <select asp-for="Prioridade" class="form-select">
            @foreach (PrioridadeTarefa prioridade in Enum.GetValues<PrioridadeTarefa>())
            {
                <option value="@prioridade">
                    @prioridade
                </option>
            }
        </select>
    </div>

    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <label class="form-label fw-semibold text-primary text-uppercase small mb-0">
                Itens da Tarefa
            </label>
            <button type="button" id="btn-add-item" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                Adicionar Novo Item
            </button>
        </div>

        <div id="itens-container">
            @if (Model?.Itens != null)
            {
                for (int i = 0; i < Model.Itens.Count; i++)
                {
                    <div class="input-group mb-2 item-linha">
                        <input type="hidden" name="Itens[@i].Id" value="@Model.Itens[i].Id" class="item-id" />

                        <div class="input-group-text">
                            <input class="form-check-input mt-0 check-status-item" type="checkbox"
                                   data-item-id="@Model.Itens[i].Id" name="Itens[@i].Concluido" value="true"
                            @(Model.Itens[i].Concluido ? "checked" : "")>
                            <input type="hidden" name="Itens[@i].Concluido" value="false">
                        </div>

                        <input type="text" name="Itens[@i].Titulo" value="@Model.Itens[i].Titulo" class="form-control" />

                        <button type="button" class="btn btn-outline-danger btn-remover-item">Remover</button>
                    </div>
                }
            }
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">
            Voltar
        </a>
        <button class="btn btn-primary rounded-pill px-4">
            Salvar
        </button>
    </div>
</form>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.getElementById('btn-add-item').addEventListener('click', function () {
            var container = document.getElementById('itens-container');
            var index = container.querySelectorAll('.item-linha').length;

            var div = document.createElement('div');
            div.className = 'input-group mb-2 item-linha';

            div.innerHTML = `
                <input type="hidden" name="Itens[${index}].Id" value="" class="item-id" />
                <div class="input-group-text">
                    <input class="form-check-input mt-0" type="checkbox" name="Itens[${index}].Concluido" value="true">
                    <input type="hidden" name="Itens[${index}].Concluido" value="false">
                </div>
                <input type="text" name="Itens[${index}].Titulo" class="form-control" placeholder="Descrição do novo item" />
                <button type="button" class="btn btn-outline-danger btn-remover-item">Remover</button>
            `;

            container.appendChild(div);
        });

        document.getElementById('itens-container').addEventListener('click', function (e) {
            if (e.target.classList.contains('btn-remover-item')) {
                e.target.closest('.item-linha').remove();

                var linhas = document.querySelectorAll('.item-linha');
                linhas.forEach(function (linha, index) {
                    var inputId = linha.querySelector('input[type="hidden"].item-id');
                    var inputCheck = linha.querySelector('input[type="checkbox"]');
                    var inputCheckHidden = linha.querySelector('input[type="hidden"][value="false"]');
                    var inputTitulo = linha.querySelector('input[type="text"]');

                    if (inputId) inputId.name = `Itens[${index}].Id`;
                    if (inputCheck) inputCheck.name = `Itens[${index}].Concluido`;
                    if (inputCheckHidden) inputCheckHidden.name = `Itens[${index}].Concluido`;
                    if (inputTitulo) inputTitulo.name = `Itens[${index}].Titulo`;
                });
            }
        });

        var checkboxes = document.querySelectorAll('.check-status-item');
        checkboxes.forEach(function (checkbox) {
            checkbox.addEventListener('change', function () {
                var itemId = this.getAttribute('data-item-id');
                var tarefaId = document.getElementById('TarefaId').value;
                var concluido = this.checked;

                if (!itemId) return;

                fetch('/Tarefas/AtualizarStatusItem', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ TarefaId: tarefaId, ItemId: itemId, Concluido: concluido })
                }).then(function (response) {
                    if (response.ok) {
                        location.reload();
                    } else {
                        alert('Erro ao atualizar o status do item.');
                    }
                });
            });
        });
    });
</script>