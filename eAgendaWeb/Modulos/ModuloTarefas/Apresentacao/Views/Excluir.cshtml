@using eAgendaWeb.Modulos.ModuloTarefas.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Tarefa";
}

@model ExcluirTarefaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width:620px;" asp-action="Excluir"
      method="post">

    <input asp-for="Id" type="hidden" />

    <div class="alert alert-warning mb-4">
        <h5 class="alert-heading">Atenção!</h5>
        <p class="mb-0">Você está prestes a excluir esta tarefa. Esta ação não poderá ser desfeita e removerá todos os
            itens vinculados.</p>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold text-primary text-uppercase small">
                Título
            </label>
            <p class="form-control-plaintext">@Model.Titulo</p>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold text-primary text-uppercase small">
                Prioridade
            </label>
            <p class="form-control-plaintext">@Model.Prioridade</p>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold text-primary text-uppercase small">
                Progresso
            </label>
            <p class="form-control-plaintext">@Model.PercentualConcluido%</p>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">
                Voltar
            </a>
            <button class="btn btn-danger rounded-pill px-4">
                Excluir
            </button>
        </div>
    </form>