@{
    Layout = "_Layout";
    ViewBag.Titulo = "Excluir Despesa";
}

@model ExcluirDespesaViewModel


<form class="card border-danger-subtle shadow-sm mx-auto p-4" style="max-width:620px;" asp-action="Excluir"
      method="post">


    <input asp-for="Id" type="hidden" />


    <h5>
        Deseja excluir a despesa?
    </h5>


    <dl class="row mt-3">

        <dt class="col-6">
            Descrição
        </dt>

        <dd class="col-6">
            @Model.Descricao
        </dd>


        <dt class="col-6">
            Valor
        </dt>

        <dd class="col-6">
            @Model.Valor.ToString("C")
        </dd>


        <dt class="col-6">
            Pagamento
        </dt>

        <dd class="col-6">
            @Model.FormaPagamento
        </dd>


    </dl>


    <div class="d-flex justify-content-end gap-2">

        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">
            Voltar
        </a>


        <button class="btn btn-danger rounded-pill px-4">
            Excluir
        </button>


    </div>


</form>