@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Compromissos";
}

@model List<ListarCompromissosViewModel>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhum compromisso cadastrado.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (ListarCompromissosViewModel p in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">@p.Assunto</h5>
                            <span class="badge text-bg-primary rounded-pill">@p.DataOcorrencia:dd/MM/yyyy</span>
                        </div>

                        <dl class="row g-2 mb-4">
                            <dt class="col-6 text-secondary fw-semibold">Horário</dt>
                            <dd class="col-6 mb-0 text-break">@p.HoraInicio.ToString(@"hh\:mm") - @p.HoraTermino.ToString(@"hh\:mm")</dd>

                            <dt class="col-6 text-secondary fw-semibold">Tipo</dt>
                            <dd class="col-6 mb-0 text-break">@p.TipoCompromisso</dd>

                            @if (!string.IsNullOrWhiteSpace(p.Local))
                            {
                                <dt class="col-6 text-secondary fw-semibold">Local</dt>
                                <dd class="col-6 mb-0 text-break">@p.Local</dd>
                            }

                            @if (!string.IsNullOrWhiteSpace(p.Link))
                            {
                                <dt class="col-6 text-secondary fw-semibold">Link</dt>
                                <dd class="col-6 mb-0 text-break">@p.Link</dd>
                            }

                            @if (p.ContatoId != null)
                            {
                                <dt class="col-6 text-secondary fw-semibold">Contato</dt>
                                <dd class="col-6 mb-0 text-break">@p.ContatoId</dd>
                            }
                        </dl>

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar" asp-route-id="@p.Id">Editar</a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir" asp-route-id="@p.Id">Excluir</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
